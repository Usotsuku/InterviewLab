# InterviewLab Backend - Environment Variables
# Copy to .env and fill in values

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URI=mongodb://localhost:27017/interviewlab

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your-random-secret-here
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
NODE_ENV=development

# ── AI Provider ─────────────────────────────────────────────────────────────
# Comma-separated list. First entry is primary.
# Supported: gemini, groq, kimi
AI_PROVIDER=gemini

# Required per active provider:
GEMINI_API_KEY=
GROQ_API_KEY=
KIMI_API_KEY=

# Optional per provider model overrides:
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.1-8b-instant
KIMI_MODEL=kimi-latest

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200,http://localhost:5173

# ── Throttler ───────────────────────────────────────────────────────────────
THROTTLER_TTL=60000
THROTTLER_LIMIT=20
